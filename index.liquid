<!-- Hero -->
<section class="hero">
  <p class="hero__eyebrow">New Collection 2024</p>
  <h1 class="hero__title">上質なものを、<br>あなたの暮らしに。</h1>
  <p class="hero__subtitle">厳選された素材と確かな品質。毎日をちょっと豊かにするアイテムをお届けします。</p>
  <a href="{{ routes.collections_url }}" class="btn btn--primary">商品を見る</a>
  <a href="/pages/about" class="btn btn--outline">ブランドについて</a>
</section>

<!-- Featured Products -->
<section class="section">
  <div class="container">
    <div class="section__heading">
      <h2>おすすめ商品</h2>
      <p>人気のアイテムをピックアップしました</p>
    </div>

    <div class="product-grid">
      {% assign featured = collections['frontpage'].products %}
      {% if featured.size > 0 %}
        {% for product in featured limit: 8 %}
          <a href="{{ product.url }}" class="product-card{% unless product.available %} sold-out{% endunless %}">
            <div class="product-card__image">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="450"
                >
              {% else %}
                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#aaa;font-size:0.8rem;">No Image</div>
              {% endif %}
            </div>
            <div class="product-card__body">
              {% if product.compare_at_price > product.price %}
                <span class="product-card__badge">SALE</span>
              {% endif %}
              {% if product.vendor != blank %}
                <p class="product-card__vendor">{{ product.vendor }}</p>
              {% endif %}
              <p class="product-card__title">{{ product.title }}</p>
              <p class="product-card__price">
                {{ product.price | money }}
                {% unless product.available %}
                  &nbsp;<span class="sold-out-label">売り切れ</span>
                {% endunless %}
              </p>
            </div>
          </a>
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <div class="product-card">
            <div class="product-card__image">
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#aaa;font-size:0.85rem;">商品画像</div>
            </div>
            <div class="product-card__body">
              <p class="product-card__vendor">BRAND</p>
              <p class="product-card__title">サンプル商品 {{ i }}</p>
              <p class="product-card__price">¥3,980</p>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <div style="text-align:center;margin-top:48px;">
      <a href="{{ routes.collections_url }}" class="btn btn--primary">すべての商品を見る</a>
    </div>
  </div>
</section>

<!-- Features Banner -->
<section style="background:#fff;padding:48px 0;border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);">
  <div class="container">
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:32px;text-align:center;">
      <div>
        <div style="font-size:2rem;margin-bottom:12px;">🚚</div>
        <p style="font-weight:700;margin-bottom:6px;">送料無料</p>
        <p style="font-size:0.85rem;color:var(--color-gray);">5,000円以上のご注文</p>
      </div>
      <div>
        <div style="font-size:2rem;margin-bottom:12px;">🔄</div>
        <p style="font-weight:700;margin-bottom:6px;">30日間返品OK</p>
        <p style="font-size:0.85rem;color:var(--color-gray);">安心の返品保証</p>
      </div>
      <div>
        <div style="font-size:2rem;margin-bottom:12px;">🔒</div>
        <p style="font-weight:700;margin-bottom:6px;">安全な決済</p>
        <p style="font-size:0.85rem;color:var(--color-gray);">SSL暗号化対応</p>
      </div>
    </div>
  </div>
</section>
